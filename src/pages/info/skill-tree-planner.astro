---
/**
 * Cisco's RPG / Passive Skill Tree 시뮬레이터 (실제 데이터 기반)
 * - 5개 클래스 (Alchemist / Blacksmith / Cook / Enchanter / Hunter)
 * - 각 클래스 61개 노드, 총 305개
 * - 클래스 탭 전환 + Pan / Zoom + 빌드 저장
 *
 * 데이터 출처: Daripher의 Passive Skill Tree mod (GitHub)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { REAL_SKILLS, CLASS_INFO, COORD_BOUNDS } from '../../data/skill-tree-real';

const base = import.meta.env.BASE_URL;
const breadcrumbs = [
  { label: '홈', href: base },
  { label: '유용한 정보', href: `${base}info/` },
  { label: '스킬 트리 찍어보기' },
];

// 클래스별로 노드 그룹화
const byClass: Record<string, typeof REAL_SKILLS> = {};
for (const node of REAL_SKILLS) {
  if (!byClass[node.classKey]) byClass[node.classKey] = [];
  byClass[node.classKey].push(node);
}
const classKeys = Object.keys(CLASS_INFO) as Array<keyof typeof CLASS_INFO>;

// 데이터를 클라이언트로 전달
const dataJson = JSON.stringify({
  skills: REAL_SKILLS,
  classes: CLASS_INFO,
  bounds: COORD_BOUNDS,
});
---

<BaseLayout
  title="스킬 트리 찍어보기 | Cisco RPG"
  description="Cisco's Fantasy Medieval RPG의 Passive Skill Tree 시뮬레이터. 5개 클래스(연금술사·대장장이·요리사·인챈터·사냥꾼) 305개 실제 노드를 직접 클릭해서 빌드를 시뮬레이션해보세요."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <article class="planner container">
    <header class="planner__header">
      <span class="mc-badge mc-badge--tag">시뮬레이터 · 실제 데이터</span>
      <h1>🌳 Passive Skill Tree 찍어보기</h1>
      <p class="planner__lead">
        <strong>Daripher의 Passive Skill Tree</strong> 모드의 실제 305개 노드 데이터를 사용한 시뮬레이터입니다.
        Cisco's RPG와 같은 모드팩에서 사용되는 시스템을 그대로 체험할 수 있습니다.
      </p>
    </header>

    <!-- 클래스 탭 -->
    <div class="planner__tabs" role="tablist" aria-label="클래스 선택">
      {classKeys.map((key, idx) => (
        <button
          type="button"
          role="tab"
          class:list={["planner__tab", { 'is-active': idx === 0 }]}
          data-class={key}
          aria-selected={idx === 0 ? 'true' : 'false'}
          style={`--tab-color:${CLASS_INFO[key].color}`}
        >
          <span class="planner__tab-emoji">{CLASS_INFO[key].emoji}</span>
          <span class="planner__tab-name">{CLASS_INFO[key].nameKo}</span>
          <span class="planner__tab-en">{CLASS_INFO[key].name}</span>
        </button>
      ))}
    </div>

    <!-- 컨트롤 바 -->
    <div class="planner__controls mc-card">
      <div class="planner__points">
        <div class="planner__points-item">
          <span class="planner__points-label">활성 노드</span>
          <span class="planner__points-value" id="nodes-count">0</span>
        </div>
        <div class="planner__points-item">
          <span class="planner__points-label">현재 클래스</span>
          <span class="planner__points-value" id="active-class-label" style="font-size: 1rem;">연금술사</span>
        </div>
      </div>
      <div class="planner__buttons">
        <button type="button" id="btn-fit" class="mc-btn">⊕ 화면에 맞춤</button>
        <button type="button" id="btn-reset-class" class="mc-btn">🔄 이 클래스 리셋</button>
        <button type="button" id="btn-reset-all" class="mc-btn">⚠ 전체 리셋</button>
        <button type="button" id="btn-save" class="mc-btn mc-btn--accent">💾 저장</button>
      </div>
    </div>

    <!-- 사용법 -->
    <details class="planner__how">
      <summary>📖 사용법 보기</summary>
      <ul>
        <li><strong>클래스 탭</strong>을 클릭해서 5개 직업 트리 사이를 전환합니다. 각 클래스는 별도로 빌드를 짤 수 있습니다.</li>
        <li>중앙의 <strong>큰 시작 노드</strong>(★)는 항상 활성화되어 있습니다. 여기서 시작합니다.</li>
        <li>활성 노드와 <strong>인접한 노드</strong>만 클릭해서 활성화할 수 있습니다.</li>
        <li>활성 노드를 다시 클릭하면 비활성화 (단, 다른 노드 연결이 끊어지면 안 됨)</li>
        <li>마우스 휠로 <strong>줌 인/아웃</strong>, 드래그로 <strong>이동</strong>할 수 있습니다.</li>
        <li><strong>💾 저장</strong>은 모든 클래스의 활성화 상태를 저장합니다.</li>
      </ul>
      <div class="planner__legend">
        <span class="legend-item"><span class="legend-dot legend-dot--minor"></span> Minor 노드 (작은 보너스)</span>
        <span class="legend-item"><span class="legend-dot legend-dot--notable"></span> Notable 노드 (큰 보너스)</span>
        <span class="legend-item"><span class="legend-dot legend-dot--keystone"></span> Keystone 노드 (고유 효과)</span>
      </div>
    </details>

    <!-- 트리 컨테이너 -->
    <div class="planner__svg-wrap">
      <svg
        id="skill-tree"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Passive Skill Tree"
        viewBox="-200 -200 400 400"
      >
        <defs>
          <radialGradient id="bgGrad" cx="50%" cy="50%" r="60%">
            <stop offset="0%" stop-color="#1A1F28" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#0A0B0D" stop-opacity="1" />
          </radialGradient>
        </defs>
        <rect x="-1000" y="-1000" width="2000" height="2000" fill="url(#bgGrad)" />
        <g id="viewport">
          <g id="links"></g>
          <g id="nodes"></g>
        </g>
      </svg>
    </div>

    <!-- 활성 노드 정보 패널 -->
    <aside class="planner__info mc-card">
      <h3>현재 클래스 활성 노드</h3>
      <ul id="active-list" class="planner__active-list">
        <li class="planner__empty">시작 노드 외에 활성화된 노드가 없습니다.</li>
      </ul>
    </aside>

    <!-- 안내 -->
    <div class="planner__notice">
      <p>
        ℹ️ 데이터는 <a href="https://github.com/Daripher/Passive-Skill-Tree" target="_blank" rel="noopener">Daripher의 Passive Skill Tree mod 저장소</a>에서 자동 추출했습니다.
        실제 게임과 동일한 노드 좌표·연결·효과를 사용하지만, 아이콘·UI는 단순화되어 있습니다.
      </p>
      <p>
        📖 시스템에 대한 자세한 설명은 <a href={`${base}info/passive-skill-tree/`}>Passive Skill Tree 가이드</a>를 참고하세요.
      </p>
    </div>
  </article>

  <script id="planner-data" type="application/json" is:inline set:html={dataJson} />

  <script is:inline>
  // ============================================
  // 스킬 트리 빌더 (실제 데이터)
  // ============================================
  (function() {
    const data = JSON.parse(document.getElementById('planner-data').textContent);
    const { skills, classes } = data;

    // 클래스별 노드 맵
    const byClass = {};
    skills.forEach(s => {
      if (!byClass[s.classKey]) byClass[s.classKey] = [];
      byClass[s.classKey].push(s);
    });

    // ID -> 노드
    const nodeMap = new Map(skills.map(s => [s.id, s]));

    // 양방향 인접 그래프 (클래스별)
    const adjacency = {};
    Object.keys(byClass).forEach(cls => {
      adjacency[cls] = new Map();
      byClass[cls].forEach(n => adjacency[cls].set(n.id, new Set()));
      byClass[cls].forEach(n => {
        const allLinks = [...(n.directLinks || []), ...(n.longLinks || [])];
        allLinks.forEach(target => {
          if (adjacency[cls].has(target)) {
            adjacency[cls].get(n.id).add(target);
            adjacency[cls].get(target).add(n.id);
          }
        });
      });
    });

    // 활성 노드 (클래스별)
    const activeByClass = {};
    Object.keys(classes).forEach(cls => {
      // 시작 노드 자동 활성화
      const startNode = byClass[cls].find(n => n.isStart);
      activeByClass[cls] = new Set(startNode ? [startNode.id] : []);
    });

    const STORAGE_KEY = 'cisco-skill-tree-real-v1';
    // 저장된 빌드 복원
    try {
      const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      Object.keys(saved).forEach(cls => {
        if (activeByClass[cls] && Array.isArray(saved[cls])) {
          saved[cls].forEach(id => {
            if (nodeMap.has(id)) activeByClass[cls].add(id);
          });
        }
      });
    } catch (e) {}

    let currentClass = Object.keys(classes)[0];

    const svg = document.getElementById('skill-tree');
    const linksGroup = document.getElementById('links');
    const nodesGroup = document.getElementById('nodes');
    const nodesCountEl = document.getElementById('nodes-count');
    const activeListEl = document.getElementById('active-list');
    const activeClassLabel = document.getElementById('active-class-label');

    // ============ 트리 렌더 ============
    function buildTree(cls) {
      // 기존 비우기
      linksGroup.innerHTML = '';
      nodesGroup.innerHTML = '';

      const nodes = byClass[cls];
      const seenLinks = new Set();

      // 연결선
      nodes.forEach(n => {
        const allLinks = [...(n.directLinks || []), ...(n.longLinks || [])];
        allLinks.forEach(targetId => {
          const key = [n.id, targetId].sort().join('|');
          if (seenLinks.has(key)) return;
          seenLinks.add(key);
          const target = nodeMap.get(targetId);
          if (!target) return;
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('class', 'link');
          line.setAttribute('data-from', n.id);
          line.setAttribute('data-to', targetId);
          line.setAttribute('x1', n.x);
          line.setAttribute('y1', n.y);
          line.setAttribute('x2', target.x);
          line.setAttribute('y2', target.y);
          line.setAttribute('stroke', '#2A3340');
          line.setAttribute('stroke-width', '0.6');
          linksGroup.appendChild(line);
        });
      });

      // 노드
      nodes.forEach(n => {
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('class', 'node node--' + n.type + (n.isStart ? ' node--start' : ''));
        g.setAttribute('data-id', n.id);
        g.setAttribute('transform', 'translate(' + n.x + ',' + n.y + ')');
        g.setAttribute('tabindex', '0');
        g.setAttribute('role', 'button');
        g.setAttribute('aria-label', n.name);

        // 노드 크기를 viewBox 기준으로 변환 (실제 size는 16~32px)
        const r = n.size * 0.35;
        const bg = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        bg.setAttribute('class', 'node__bg');
        bg.setAttribute('r', String(r));
        g.appendChild(bg);

        const border = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        border.setAttribute('class', 'node__border');
        border.setAttribute('r', String(r));
        border.setAttribute('fill', 'none');
        border.setAttribute('stroke-width', String(r * 0.15));
        g.appendChild(border);

        if (n.isStart) {
          const star = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          star.setAttribute('class', 'node__icon');
          star.setAttribute('text-anchor', 'middle');
          star.setAttribute('dy', '3');
          star.textContent = '★';
          g.appendChild(star);
        }

        // 클릭 / 호버
        g.addEventListener('click', (e) => {
          e.stopPropagation();
          handleNodeClick(n.id);
        });
        g.addEventListener('mouseenter', () => showTooltip(g, n));
        g.addEventListener('mouseleave', hideTooltip);
        g.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            handleNodeClick(n.id);
          }
        });

        nodesGroup.appendChild(g);
      });

      // viewBox를 클래스 트리 범위에 맞게 설정
      fitViewBox();
      updateVisuals();
    }

    // ============ 인접/연결 검증 ============
    function canActivate(cls, id) {
      if (activeByClass[cls].has(id)) return false;
      const adj = adjacency[cls].get(id);
      if (!adj) return false;
      for (const n of adj) {
        if (activeByClass[cls].has(n)) return true;
      }
      return false;
    }

    function canDeactivate(cls, id) {
      const node = nodeMap.get(id);
      if (!node || node.isStart) return false;
      if (!activeByClass[cls].has(id)) return false;
      // BFS: id를 제외한 상태에서 시작 노드에서 모든 활성 노드 도달 가능?
      const startNode = byClass[cls].find(n => n.isStart);
      if (!startNode) return true;
      const without = new Set(activeByClass[cls]);
      without.delete(id);
      const visited = new Set();
      const queue = [startNode.id];
      while (queue.length > 0) {
        const cur = queue.shift();
        if (visited.has(cur)) continue;
        visited.add(cur);
        const adj = adjacency[cls].get(cur);
        if (!adj) continue;
        adj.forEach(neighbor => {
          if (without.has(neighbor) && !visited.has(neighbor)) {
            queue.push(neighbor);
          }
        });
      }
      for (const id of without) {
        if (!visited.has(id)) return false;
      }
      return true;
    }

    function handleNodeClick(id) {
      const node = nodeMap.get(id);
      if (!node || node.isStart) return;
      const cls = currentClass;
      if (activeByClass[cls].has(id)) {
        if (!canDeactivate(cls, id)) {
          alert('이 노드를 제거하면 다른 노드가 시작점에서 끊어집니다.');
          return;
        }
        activeByClass[cls].delete(id);
      } else {
        if (!canActivate(cls, id)) {
          return;
        }
        activeByClass[cls].add(id);
      }
      updateVisuals();
    }

    // ============ 시각 업데이트 ============
    function updateVisuals() {
      const cls = currentClass;
      const color = classes[cls].color;
      activeClassLabel.textContent = classes[cls].nameKo;
      // 시작 노드 제외 카운트
      const cnt = activeByClass[cls].size - 1;
      nodesCountEl.textContent = String(Math.max(0, cnt));

      nodesGroup.querySelectorAll('.node').forEach(g => {
        const id = g.getAttribute('data-id');
        const isActive = activeByClass[cls].has(id);
        const canAct = !isActive && canActivate(cls, id);
        g.classList.toggle('is-active', isActive);
        g.classList.toggle('is-available', canAct);
        g.classList.toggle('is-locked', !isActive && !canAct);
        const bg = g.querySelector('.node__bg');
        const border = g.querySelector('.node__border');
        if (isActive) {
          bg.setAttribute('fill', color);
          bg.setAttribute('fill-opacity', '0.85');
          border.setAttribute('stroke', color);
          border.setAttribute('stroke-opacity', '1');
        } else if (canAct) {
          bg.setAttribute('fill', color);
          bg.setAttribute('fill-opacity', '0.18');
          border.setAttribute('stroke', color);
          border.setAttribute('stroke-opacity', '0.55');
        } else {
          bg.setAttribute('fill', '#1A1C21');
          bg.setAttribute('fill-opacity', '1');
          border.setAttribute('stroke', '#3A4150');
          border.setAttribute('stroke-opacity', '1');
        }
      });

      linksGroup.querySelectorAll('.link').forEach(line => {
        const from = line.getAttribute('data-from');
        const to = line.getAttribute('data-to');
        const both = activeByClass[cls].has(from) && activeByClass[cls].has(to);
        if (both) {
          line.setAttribute('stroke', color);
          line.setAttribute('stroke-opacity', '0.85');
          line.setAttribute('stroke-width', '1');
        } else {
          line.setAttribute('stroke', '#2A3340');
          line.setAttribute('stroke-opacity', '0.6');
          line.setAttribute('stroke-width', '0.6');
        }
      });

      // 활성 노드 패널
      const items = [];
      activeByClass[cls].forEach(id => {
        const n = nodeMap.get(id);
        if (!n || n.isStart) return;
        const bonusHtml = n.bonuses && n.bonuses.length > 0
          ? '<ul class="planner__bonuses">' + n.bonuses.map(b => '<li>' + escapeHtml(b) + '</li>').join('') + '</ul>'
          : '<div class="planner__bonuses-empty">효과 없음</div>';
        items.push(
          '<li class="planner__active-item" style="border-left-color:' + color + '">' +
          '<div class="planner__active-name">' + escapeHtml(n.name) + ' <span class="planner__active-type">(' + n.type + ')</span></div>' +
          bonusHtml +
          '</li>'
        );
      });
      if (items.length === 0) {
        activeListEl.innerHTML = '<li class="planner__empty">시작 노드 외에 활성화된 노드가 없습니다.</li>';
      } else {
        activeListEl.innerHTML = items.join('');
      }
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ============ 툴팁 ============
    let tooltipEl = null;
    function showTooltip(g, node) {
      if (!tooltipEl) {
        tooltipEl = document.createElement('div');
        tooltipEl.className = 'mc-tooltip planner__tooltip';
        document.body.appendChild(tooltipEl);
      }
      const bonuses = node.bonuses && node.bonuses.length > 0
        ? node.bonuses.map(b => '<div>• ' + escapeHtml(b) + '</div>').join('')
        : '<div style="color:#888">효과 없음</div>';
      const typeLabel = {
        start: '★ 시작',
        keystone: '⚡ KEYSTONE',
        notable: '◆ NOTABLE',
        minor: '· Minor',
      }[node.type] || node.type;
      tooltipEl.innerHTML =
        '<p class="mc-tooltip__title">' + escapeHtml(node.name) + '</p>' +
        '<div class="mc-tooltip__desc">' + bonuses + '</div>' +
        '<p class="mc-tooltip__rare">' + typeLabel + '</p>';
      const rect = g.getBoundingClientRect();
      tooltipEl.style.position = 'fixed';
      tooltipEl.style.left = (rect.right + 12) + 'px';
      tooltipEl.style.top = (rect.top) + 'px';
      tooltipEl.style.zIndex = '1000';
      tooltipEl.style.maxWidth = '280px';
      tooltipEl.style.pointerEvents = 'none';
      // 화면 밖으로 나가면 왼쪽으로 이동
      const tipRect = tooltipEl.getBoundingClientRect();
      if (tipRect.right > window.innerWidth - 20) {
        tooltipEl.style.left = (rect.left - tipRect.width - 12) + 'px';
      }
    }
    function hideTooltip() {
      if (tooltipEl) tooltipEl.remove();
      tooltipEl = null;
    }

    // ============ Pan / Zoom ============
    let viewBox = { x: -200, y: -200, w: 400, h: 400 };
    function setViewBox() {
      svg.setAttribute('viewBox', viewBox.x + ' ' + viewBox.y + ' ' + viewBox.w + ' ' + viewBox.h);
    }
    function fitViewBox() {
      const nodes = byClass[currentClass];
      if (!nodes.length) return;
      const xs = nodes.map(n => n.x);
      const ys = nodes.map(n => n.y);
      const minX = Math.min(...xs) - 25;
      const maxX = Math.max(...xs) + 25;
      const minY = Math.min(...ys) - 25;
      const maxY = Math.max(...ys) + 25;
      const w = maxX - minX;
      const h = maxY - minY;
      const size = Math.max(w, h);
      const cx = (minX + maxX) / 2;
      const cy = (minY + maxY) / 2;
      viewBox = { x: cx - size / 2, y: cy - size / 2, w: size, h: size };
      setViewBox();
    }

    // 마우스 휠 줌
    svg.addEventListener('wheel', (e) => {
      e.preventDefault();
      const rect = svg.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      // SVG 좌표계로 변환
      const svgX = viewBox.x + (mx / rect.width) * viewBox.w;
      const svgY = viewBox.y + (my / rect.height) * viewBox.h;
      const factor = e.deltaY > 0 ? 1.18 : 1 / 1.18;
      const newW = viewBox.w * factor;
      const newH = viewBox.h * factor;
      // 확대 한도
      if (newW < 60 || newW > 1200) return;
      viewBox.x = svgX - (mx / rect.width) * newW;
      viewBox.y = svgY - (my / rect.height) * newH;
      viewBox.w = newW;
      viewBox.h = newH;
      setViewBox();
    }, { passive: false });

    // 드래그 팬
    let isPanning = false;
    let panStart = { x: 0, y: 0, vbX: 0, vbY: 0 };
    svg.addEventListener('mousedown', (e) => {
      // 노드 위에서 클릭 시 팬 시작 안 함
      if (e.target.closest('.node')) return;
      isPanning = true;
      panStart.x = e.clientX;
      panStart.y = e.clientY;
      panStart.vbX = viewBox.x;
      panStart.vbY = viewBox.y;
      svg.style.cursor = 'grabbing';
    });
    window.addEventListener('mousemove', (e) => {
      if (!isPanning) return;
      const rect = svg.getBoundingClientRect();
      const dx = (e.clientX - panStart.x) * (viewBox.w / rect.width);
      const dy = (e.clientY - panStart.y) * (viewBox.h / rect.height);
      viewBox.x = panStart.vbX - dx;
      viewBox.y = panStart.vbY - dy;
      setViewBox();
    });
    window.addEventListener('mouseup', () => {
      isPanning = false;
      svg.style.cursor = '';
    });
    // 터치 (모바일)
    let touchStart = null;
    let pinchStart = null;
    svg.addEventListener('touchstart', (e) => {
      if (e.touches.length === 1) {
        touchStart = {
          x: e.touches[0].clientX,
          y: e.touches[0].clientY,
          vbX: viewBox.x,
          vbY: viewBox.y,
        };
      } else if (e.touches.length === 2) {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        pinchStart = { dist: Math.hypot(dx, dy), w: viewBox.w, h: viewBox.h };
      }
    }, { passive: true });
    svg.addEventListener('touchmove', (e) => {
      if (e.touches.length === 1 && touchStart) {
        const rect = svg.getBoundingClientRect();
        const dx = (e.touches[0].clientX - touchStart.x) * (viewBox.w / rect.width);
        const dy = (e.touches[0].clientY - touchStart.y) * (viewBox.h / rect.height);
        viewBox.x = touchStart.vbX - dx;
        viewBox.y = touchStart.vbY - dy;
        setViewBox();
        e.preventDefault();
      } else if (e.touches.length === 2 && pinchStart) {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        const dist = Math.hypot(dx, dy);
        const factor = pinchStart.dist / dist;
        viewBox.w = Math.max(60, Math.min(1200, pinchStart.w * factor));
        viewBox.h = Math.max(60, Math.min(1200, pinchStart.h * factor));
        setViewBox();
        e.preventDefault();
      }
    }, { passive: false });
    svg.addEventListener('touchend', () => {
      touchStart = null;
      pinchStart = null;
    });

    // ============ 클래스 탭 ============
    document.querySelectorAll('.planner__tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.planner__tab').forEach(b => {
          b.classList.remove('is-active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('is-active');
        btn.setAttribute('aria-selected', 'true');
        currentClass = btn.getAttribute('data-class');
        buildTree(currentClass);
      });
    });

    // ============ 컨트롤 버튼 ============
    document.getElementById('btn-fit').addEventListener('click', fitViewBox);

    document.getElementById('btn-reset-class').addEventListener('click', () => {
      if (!confirm('현재 클래스의 모든 노드를 리셋할까요?')) return;
      const cls = currentClass;
      const startNode = byClass[cls].find(n => n.isStart);
      activeByClass[cls] = new Set(startNode ? [startNode.id] : []);
      updateVisuals();
    });

    document.getElementById('btn-reset-all').addEventListener('click', () => {
      if (!confirm('정말 모든 클래스의 빌드를 초기화할까요?')) return;
      Object.keys(classes).forEach(cls => {
        const startNode = byClass[cls].find(n => n.isStart);
        activeByClass[cls] = new Set(startNode ? [startNode.id] : []);
      });
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      updateVisuals();
    });

    document.getElementById('btn-save').addEventListener('click', () => {
      try {
        const out = {};
        Object.keys(activeByClass).forEach(cls => {
          out[cls] = Array.from(activeByClass[cls]);
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(out));
        alert('5개 클래스의 빌드가 모두 저장되었습니다!');
      } catch (e) {
        alert('저장 실패: ' + e.message);
      }
    });

    // 초기화
    buildTree(currentClass);
  })();
  </script>
</BaseLayout>

