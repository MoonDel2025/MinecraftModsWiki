---
/**
 * Cisco's RPG 스킬 트리 찍어보기 (시뮬레이터)
 * - SVG로 노드/연결선 그리기
 * - 클라이언트 사이드 JS로 인터랙션
 * - localStorage에 빌드 저장
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SKILL_NODES, NODE_COSTS, TOTAL_POINTS, CLASS_COLORS } from '../../data/skill-tree';

const base = import.meta.env.BASE_URL;
const breadcrumbs = [
  { label: '홈', href: base },
  { label: '유용한 정보', href: `${base}info/` },
  { label: '스킬 트리 찍어보기' },
];

// 모든 연결선 (양방향 중복 제거)
const links = new Set<string>();
SKILL_NODES.forEach(node => {
  node.links.forEach(targetId => {
    const key = [node.id, targetId].sort().join('|');
    links.add(key);
  });
});
const linkPairs = Array.from(links).map(k => k.split('|') as [string, string]);

// 노드 좌표를 JSON으로 직렬화하여 클라이언트로 전달
const nodesJson = JSON.stringify(
  SKILL_NODES.map(n => ({
    id: n.id,
    name: n.name,
    desc: n.desc,
    type: n.type,
    classKey: n.classKey,
    links: n.links,
    isStart: n.isStart || false,
  }))
);
const costsJson = JSON.stringify(NODE_COSTS);
const colorsJson = JSON.stringify(CLASS_COLORS);
---

<BaseLayout
  title="Cisco's RPG 스킬 트리 찍어보기"
  description="Cisco's Fantasy Medieval RPG의 Passive Skill Tree를 직접 클릭해서 빌드를 시뮬레이션해보세요. 6개 클래스, 핵심 노드, 키스톤 효과를 미리 체험할 수 있습니다."
  breadcrumbs={breadcrumbs}
>
  <article class="planner container">
    <header class="planner__header">
      <span class="mc-badge mc-badge--tag">시뮬레이터</span>
      <h1>🌳 Cisco's RPG 스킬 트리 찍어보기</h1>
      <p class="planner__lead">
        실제 모드의 588개 노드를 단순화한 시뮬레이터입니다.
        6개 클래스의 핵심 노드를 직접 찍어보면서 빌드를 미리 체험할 수 있습니다.
      </p>
    </header>

    <!-- 컨트롤 바 -->
    <div class="planner__controls mc-card">
      <div class="planner__points">
        <div class="planner__points-item">
          <span class="planner__points-label">사용 포인트</span>
          <span class="planner__points-value" id="points-used">0</span>
          <span class="planner__points-sep">/</span>
          <span class="planner__points-total">{TOTAL_POINTS}</span>
        </div>
        <div class="planner__points-item">
          <span class="planner__points-label">활성 노드</span>
          <span class="planner__points-value" id="nodes-count">0</span>
        </div>
      </div>
      <div class="planner__buttons">
        <button type="button" id="btn-reset" class="mc-btn">🔄 리셋</button>
        <button type="button" id="btn-save" class="mc-btn mc-btn--accent">💾 빌드 저장</button>
      </div>
    </div>

    <!-- 사용법 -->
    <details class="planner__how">
      <summary>📖 사용법 보기</summary>
      <ul>
        <li><strong>중앙 CORE</strong>는 항상 활성화되어 있습니다. 여기서 시작하세요.</li>
        <li>활성화된 노드에 <strong>인접한 노드</strong>만 클릭해서 활성화할 수 있습니다.</li>
        <li>노드 위에 마우스를 올리면 효과 설명이 표시됩니다.</li>
        <li>활성 노드를 다시 클릭하면 비활성화됩니다 (단, 다른 노드와 연결이 끊어지면 안 됨).</li>
        <li>리셋 버튼으로 처음부터 다시 시작할 수 있습니다.</li>
      </ul>
      <div class="planner__legend">
        <span class="legend-item"><span class="legend-dot legend-dot--minor"></span> Minor (1 포인트)</span>
        <span class="legend-item"><span class="legend-dot legend-dot--notable"></span> Notable (2 포인트)</span>
        <span class="legend-item"><span class="legend-dot legend-dot--keystone"></span> Keystone (3 포인트)</span>
      </div>
    </details>

    <!-- 스킬 트리 SVG -->
    <div class="planner__svg-wrap">
      <svg
        id="skill-tree"
        viewBox="0 0 1000 1000"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Cisco RPG 스킬 트리"
      >
        <!-- 배경 그라데이션 -->
        <defs>
          <radialGradient id="bgGrad" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#1A1F28" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#0C0D0F" stop-opacity="0.9" />
          </radialGradient>
          <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
        <rect width="1000" height="1000" fill="url(#bgGrad)" />

        <!-- 연결선 (먼저 그려야 노드 뒤에 깔림) -->
        <g id="links">
          {linkPairs.map(([a, b]) => {
            const na = SKILL_NODES.find(n => n.id === a);
            const nb = SKILL_NODES.find(n => n.id === b);
            if (!na || !nb) return null;
            return (
              <line
                class="link"
                data-from={a}
                data-to={b}
                x1={na.x}
                y1={na.y}
                x2={nb.x}
                y2={nb.y}
                stroke="#32363F"
                stroke-width="2"
              />
            );
          })}
        </g>

        <!-- 노드 -->
        <g id="nodes">
          {SKILL_NODES.map(node => (
            <g
              class={`node node--${node.type} ${node.isStart ? 'node--start' : ''}`}
              data-id={node.id}
              data-class={node.classKey}
              transform={`translate(${node.x}, ${node.y})`}
              tabindex="0"
              role="button"
              aria-label={node.name}
            >
              <circle class="node__bg" r={node.type === 'keystone' ? 22 : node.type === 'notable' ? 17 : 12} />
              <circle class="node__border" r={node.type === 'keystone' ? 22 : node.type === 'notable' ? 17 : 12} fill="none" stroke-width="3" />
              {node.isStart && (
                <text class="node__icon" text-anchor="middle" dy="5">★</text>
              )}
            </g>
          ))}
        </g>
      </svg>
    </div>

    <!-- 활성 노드 정보 패널 -->
    <aside class="planner__info mc-card">
      <h3>활성화된 노드 효과</h3>
      <ul id="active-list" class="planner__active-list">
        <li class="planner__empty">아직 활성화된 노드가 없습니다.</li>
      </ul>
    </aside>

    <!-- 안내 -->
    <div class="planner__notice">
      <p>
        ℹ️ 이 시뮬레이터는 실제 게임의 시스템을 단순화한 학습용 도구입니다.
        실제 모드의 588개 노드 중 일부만 구현되어 있으며, 효과 수치도 예시입니다.
        정확한 정보는 <a href="https://ciscos-rpg.fandom.com/wiki/Passive_Skill_Tree" target="_blank" rel="noopener">Cisco's RPG Wiki</a>를 참고하세요.
      </p>
      <p>
        📖 시스템 자체에 대한 자세한 설명은 <a href={`${base}info/passive-skill-tree/`}>Passive Skill Tree 가이드</a>를 읽어보세요.
      </p>
    </div>
  </article>

  <!-- 데이터를 클라이언트로 전달 -->
  <script id="planner-data" type="application/json" set:html={JSON.stringify({
    nodes: JSON.parse(nodesJson),
    costs: JSON.parse(costsJson),
    colors: JSON.parse(colorsJson),
    totalPoints: TOTAL_POINTS,
  })} />

  <script is:inline>
    // ============================================
    // 스킬 트리 빌더 - 클라이언트 로직
    // ============================================
    (function() {
      const dataEl = document.getElementById('planner-data');
      const data = JSON.parse(dataEl.textContent);
      const { nodes, costs, colors, totalPoints } = data;

      const nodeMap = new Map(nodes.map(n => [n.id, n]));
      // 양방향 인접 그래프 만들기
      const adjacency = new Map();
      nodes.forEach(n => adjacency.set(n.id, new Set()));
      nodes.forEach(n => {
        n.links.forEach(target => {
          adjacency.get(n.id).add(target);
          if (adjacency.has(target)) adjacency.get(target).add(n.id);
        });
      });

      // 활성화된 노드 (코어는 항상 활성)
      const activeSet = new Set(['core']);

      const STORAGE_KEY = 'cisco-skill-tree-build-v1';
      // 저장된 빌드 복원
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          const parsed = JSON.parse(saved);
          if (Array.isArray(parsed)) {
            parsed.forEach(id => {
              if (nodeMap.has(id)) activeSet.add(id);
            });
          }
        }
      } catch (e) { /* ignore */ }

      const svg = document.getElementById('skill-tree');
      const linksGroup = document.getElementById('links');
      const nodesGroup = document.getElementById('nodes');
      const pointsUsedEl = document.getElementById('points-used');
      const nodesCountEl = document.getElementById('nodes-count');
      const activeListEl = document.getElementById('active-list');

      function getCost(nodeId) {
        const n = nodeMap.get(nodeId);
        if (!n || nodeId === 'core') return 0;
        return costs[n.type] || 1;
      }

      function calcUsedPoints() {
        let total = 0;
        activeSet.forEach(id => { total += getCost(id); });
        return total;
      }

      // 어떤 노드가 활성 가능한가? (코어 또는 활성 노드와 인접)
      function canActivate(nodeId) {
        if (activeSet.has(nodeId)) return false;
        const adj = adjacency.get(nodeId);
        if (!adj) return false;
        for (const neighbor of adj) {
          if (activeSet.has(neighbor)) return true;
        }
        return false;
      }

      // 어떤 노드를 비활성화 할 수 있는가? (제거해도 다른 활성 노드들이 코어와 연결 유지되는가)
      function canDeactivate(nodeId) {
        if (nodeId === 'core') return false;
        if (!activeSet.has(nodeId)) return false;
        // 이 노드를 뺀 상태로 BFS 해서 모든 활성 노드가 코어에서 도달 가능한지 확인
        const without = new Set(activeSet);
        without.delete(nodeId);
        if (!without.has('core')) return true;
        const visited = new Set();
        const queue = ['core'];
        while (queue.length > 0) {
          const cur = queue.shift();
          if (visited.has(cur)) continue;
          visited.add(cur);
          const adj = adjacency.get(cur);
          if (!adj) continue;
          adj.forEach(neighbor => {
            if (without.has(neighbor) && !visited.has(neighbor)) {
              queue.push(neighbor);
            }
          });
        }
        // 모든 활성(without) 노드가 visited에 있어야 함
        for (const id of without) {
          if (!visited.has(id)) return false;
        }
        return true;
      }

      function render() {
        const used = calcUsedPoints();
        pointsUsedEl.textContent = String(used);
        nodesCountEl.textContent = String(activeSet.size - 1); // 코어 제외

        // 노드 상태 업데이트
        nodesGroup.querySelectorAll('.node').forEach(g => {
          const id = g.getAttribute('data-id');
          const node = nodeMap.get(id);
          const classKey = node.classKey;
          const color = colors[classKey] || '#888';

          const isActive = activeSet.has(id);
          const canAct = !isActive && canActivate(id);

          g.classList.toggle('is-active', isActive);
          g.classList.toggle('is-available', canAct);
          g.classList.toggle('is-locked', !isActive && !canAct);

          const bg = g.querySelector('.node__bg');
          const border = g.querySelector('.node__border');
          if (isActive) {
            bg.setAttribute('fill', color);
            bg.setAttribute('fill-opacity', '0.85');
            border.setAttribute('stroke', color);
            border.setAttribute('stroke-opacity', '1');
            g.style.filter = 'drop-shadow(0 0 6px ' + color + 'aa)';
          } else if (canAct) {
            bg.setAttribute('fill', color);
            bg.setAttribute('fill-opacity', '0.18');
            border.setAttribute('stroke', color);
            border.setAttribute('stroke-opacity', '0.6');
            g.style.filter = '';
          } else {
            bg.setAttribute('fill', '#1A1C21');
            bg.setAttribute('fill-opacity', '1');
            border.setAttribute('stroke', '#32363F');
            border.setAttribute('stroke-opacity', '1');
            g.style.filter = '';
          }
        });

        // 연결선 상태 업데이트
        linksGroup.querySelectorAll('.link').forEach(line => {
          const from = line.getAttribute('data-from');
          const to = line.getAttribute('data-to');
          const bothActive = activeSet.has(from) && activeSet.has(to);
          if (bothActive) {
            const node = nodeMap.get(from === 'core' ? to : from);
            const color = colors[node.classKey] || '#fff';
            line.setAttribute('stroke', color);
            line.setAttribute('stroke-opacity', '0.8');
            line.setAttribute('stroke-width', '3');
          } else {
            line.setAttribute('stroke', '#32363F');
            line.setAttribute('stroke-opacity', '1');
            line.setAttribute('stroke-width', '2');
          }
        });

        // 활성 노드 목록 패널
        if (activeSet.size <= 1) {
          activeListEl.innerHTML = '<li class="planner__empty">아직 활성화된 노드가 없습니다.</li>';
        } else {
          const items = [];
          // 클래스별로 그룹화
          const byClass = {};
          activeSet.forEach(id => {
            if (id === 'core') return;
            const n = nodeMap.get(id);
            if (!byClass[n.classKey]) byClass[n.classKey] = [];
            byClass[n.classKey].push(n);
          });
          Object.keys(byClass).forEach(classKey => {
            const color = colors[classKey];
            byClass[classKey].forEach(n => {
              items.push(
                '<li class="planner__active-item" style="border-left-color:' + color + '">' +
                '<div class="planner__active-name">' + n.name +
                ' <span class="planner__active-cost">(-' + getCost(n.id) + ')</span>' +
                '</div>' +
                '<div class="planner__active-desc">' + n.desc + '</div>' +
                '</li>'
              );
            });
          });
          activeListEl.innerHTML = items.join('');
        }
      }

      function activate(id) {
        const used = calcUsedPoints();
        const cost = getCost(id);
        if (used + cost > totalPoints) {
          alert('포인트가 부족합니다! (남은 포인트: ' + (totalPoints - used) + ', 필요: ' + cost + ')');
          return;
        }
        if (!canActivate(id)) return;
        activeSet.add(id);
        render();
      }

      function deactivate(id) {
        if (!canDeactivate(id)) {
          alert('이 노드를 제거하면 다른 노드가 코어에서 끊어집니다.');
          return;
        }
        activeSet.delete(id);
        render();
      }

      // 클릭 이벤트
      nodesGroup.querySelectorAll('.node').forEach(g => {
        const id = g.getAttribute('data-id');
        if (id === 'core') return; // 코어는 조작 불가

        g.addEventListener('click', () => {
          if (activeSet.has(id)) {
            deactivate(id);
          } else {
            activate(id);
          }
        });

        g.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            g.dispatchEvent(new Event('click'));
          }
        });

        // 툴팁
        const node = nodeMap.get(id);
        g.addEventListener('mouseenter', () => showTooltip(g, node));
        g.addEventListener('mouseleave', hideTooltip);
      });

      // 툴팁
      let tooltipEl = null;
      function showTooltip(g, node) {
        if (!tooltipEl) {
          tooltipEl = document.createElement('div');
          tooltipEl.className = 'mc-tooltip planner__tooltip';
          document.body.appendChild(tooltipEl);
        }
        const cost = getCost(node.id);
        tooltipEl.innerHTML =
          '<p class="mc-tooltip__title">' + node.name + '</p>' +
          '<p class="mc-tooltip__desc">' + node.desc + '</p>' +
          '<p class="mc-tooltip__rare">' + (node.type === 'keystone' ? '⚡ KEYSTONE' : node.type === 'notable' ? '★ NOTABLE' : 'Minor') +
          ' · 비용: ' + cost + '</p>';
        const rect = g.getBoundingClientRect();
        tooltipEl.style.position = 'fixed';
        tooltipEl.style.left = (rect.left + rect.width + 12) + 'px';
        tooltipEl.style.top = (rect.top) + 'px';
        tooltipEl.style.zIndex = '1000';
        tooltipEl.style.maxWidth = '260px';
        tooltipEl.style.pointerEvents = 'none';
      }
      function hideTooltip() {
        if (tooltipEl) tooltipEl.remove();
        tooltipEl = null;
      }

      // 컨트롤 버튼
      document.getElementById('btn-reset').addEventListener('click', () => {
        if (!confirm('정말 모든 노드를 초기화하시겠습니까?')) return;
        activeSet.clear();
        activeSet.add('core');
        try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
        render();
      });

      document.getElementById('btn-save').addEventListener('click', () => {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(activeSet)));
          alert('빌드가 저장되었습니다! 다음 방문 시 자동으로 불러옵니다.');
        } catch (e) {
          alert('저장에 실패했습니다.');
        }
      });

      // 초기 렌더
      render();
    })();
  </script>
</BaseLayout>

<style>
  .planner {
    padding: var(--space-6) 0;
    max-width: 1100px;
  }

  .planner__header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .planner__header h1 {
    font-size: var(--font-size-3xl);
    margin: var(--space-3) 0;
  }

  .planner__lead {
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* 컨트롤 바 */
  .planner__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-4);
  }

  .planner__points {
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }

  .planner__points-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .planner__points-label {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }

  .planner__points-value {
    font-size: var(--font-size-2xl);
    font-weight: 800;
    color: var(--color-diamond);
    font-family: var(--font-mono);
  }

  .planner__points-sep,
  .planner__points-total {
    font-size: var(--font-size-lg);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .planner__buttons {
    display: flex;
    gap: var(--space-2);
  }

  /* 사용법 */
  .planner__how {
    margin-bottom: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: rgba(74,237,217,0.04);
    border: 1px solid rgba(74,237,217,0.15);
    border-radius: var(--radius-md);
  }

  .planner__how summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-diamond);
    font-size: var(--font-size-sm);
  }

  .planner__how ul {
    list-style: disc;
    padding-left: var(--space-6);
    margin-top: var(--space-3);
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }

  .planner__legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255,255,255,0.05);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .legend-dot {
    display: inline-block;
    border-radius: 50%;
    background: var(--color-diamond);
  }
  .legend-dot--minor { width: 12px; height: 12px; }
  .legend-dot--notable { width: 16px; height: 16px; }
  .legend-dot--keystone { width: 20px; height: 20px; }

  /* SVG */
  .planner__svg-wrap {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0;
    margin-bottom: var(--space-4);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  #skill-tree {
    display: block;
    width: 100%;
