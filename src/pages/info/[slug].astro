---
/**
 * 유용한 정보 상세 페이지
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModpackCard from '../../components/ModpackCard.astro';
import { getAllInfo, getInfoBySlug, getRelatedModpacks } from '../../utils/data';
import { parseMarkdown } from '../../utils/markdown';

export function getStaticPaths() {
  const articles = getAllInfo();
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getInfoBySlug(slug!);

if (!article) {
  return Astro.redirect('/404');
}

const base = import.meta.env.BASE_URL;
const relatedModpacks = getRelatedModpacks(article.relatedModpacks);
const bodyHtml = parseMarkdown(article.body);

const breadcrumbs = [
  { label: '홈', href: base },
  { label: '유용한 정보', href: `${base}info/` },
  { label: article.title },
];
---

<BaseLayout
  title={article.title}
  description={article.summary}
  breadcrumbs={breadcrumbs}
>
  <article class="info-detail container">
    <header class="info-detail__header">
      <div class="info-detail__meta">
        <span class="mc-badge mc-badge--tag">{article.category}</span>
        <time class="info-detail__date" datetime={article.publishedDate}>
          📅 {article.publishedDate}
        </time>
      </div>
      <h1>{article.title}</h1>
      <p class="info-detail__summary">{article.summary}</p>
      <div class="info-detail__tags">
        {article.tags.map(tag => (
          <span class="mc-badge mc-badge--tag">#{tag}</span>
        ))}
      </div>
    </header>

    <div class="info-detail__body prose" set:html={bodyHtml} />

    {relatedModpacks.length > 0 && (
      <section class="detail-section">
        <h2 class="section-title">📦 관련 모드팩</h2>
        <div class="modpack-grid">
          {relatedModpacks.map(mp => (
            <ModpackCard
              slug={mp.slug}
              name={mp.name}
              summary={mp.summary}
              minecraftVersion={mp.minecraftVersion}
              loader={mp.loader}
              difficulty={mp.difficulty}
              tags={mp.tags}
              coverImage={mp.coverImage}
            />
          ))}
        </div>
      </section>
    )}

    <div class="info-detail__nav">
      <a href={`${base}info/`} class="mc-btn">← 모든 글 보기</a>
    </div>
  </article>
</BaseLayout>

<style>
  .info-detail {
    padding: var(--space-6) 0;
    max-width: 820px;
  }

  .info-detail__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-color);
  }

  .info-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .info-detail__date {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .info-detail__header h1 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .info-detail__summary {
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .info-detail__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  /* 본문 prose 스타일 */
  .prose {
    color: var(--text-secondary);
    line-height: 1.85;
    font-size: var(--font-size-base);
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--text-heading);
    margin-top: var(--space-10);
    margin-bottom: var(--space-3);
    line-height: 1.4;
  }

  .prose :global(h3) {
    font-size: var(--font-size-xl);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-color);
  }

  .prose :global(h4) {
    font-size: var(--font-size-lg);
    color: var(--color-end-glow);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 700;
  }

  .prose :global(code) {
    background: var(--bg-card);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-diamond);
    border: 1px solid var(--border-color);
  }

  .prose :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: var(--space-4) 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: var(--font-size-sm);
    border: none;
    color: var(--text-primary);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    background: rgba(252,219,5,0.04);
    padding: var(--space-3) var(--space-4);
    margin: var(--space-4) 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .prose :global(blockquote p) {
    color: var(--text-secondary);
    margin: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: var(--space-3) 0;
    padding-left: var(--space-6);
    list-style: revert;
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
    padding-left: var(--space-1);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-4) 0;
    font-size: var(--font-size-sm);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .prose :global(thead) {
    background: var(--bg-elevated);
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-2) var(--space-4);
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .prose :global(th) {
    color: var(--text-heading);
    font-weight: 700;
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tbody tr:hover) {
    background: rgba(255,255,255,0.02);
  }

  .detail-section {
    margin-top: var(--space-12);
  }

  .modpack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .info-detail__nav {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-color);
    text-align: center;
  }

  @media (min-width: 768px) {
    .modpack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
