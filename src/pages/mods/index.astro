---
/**
 * 모드 목록 페이지
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModCard from '../../components/ModCard.astro';
import TagList from '../../components/TagList.astro';
import { getAllMods, getAllCategories } from '../../utils/data';

const base = import.meta.env.BASE_URL;
const mods = getAllMods();
const categories = getAllCategories();
const tag = Astro.url.searchParams.get('tag');
const filteredMods = tag
  ? mods.filter(m => m.tags.includes(tag) || m.category === tag)
  : mods;

const breadcrumbs = [
  { label: '홈', href: base },
  { label: '모드' },
];
---

<BaseLayout
  title="모드 목록"
  description="마인크래프트 인기 모드를 검색하고, 어떤 모드팩에 포함되어 있는지 확인하세요."
  breadcrumbs={breadcrumbs}
>
  <section class="section container">
    <div class="page-header">
      <h1 class="page-header__title">모드 목록</h1>
      <p class="page-header__desc">
        총 {mods.length}개의 모드 정보가 있습니다.
        {tag && <span>현재 필터: <strong>{tag}</strong></span>}
      </p>
    </div>

    <!-- 카테고리 필터 -->
    <div class="filter-bar">
      <TagList tags={categories} baseUrl={`${base}mods/`} activeTag={tag || undefined} />
    </div>

    <!-- 검색 -->
    <div class="search-bar">
      <input
        type="search"
        id="mod-search"
        class="mc-search"
        placeholder="모드 이름으로 검색..."
        aria-label="모드 검색"
        style="padding-left: var(--space-4);"
      />
    </div>

    <!-- 모드 그리드 -->
    <div class="card-grid" id="mod-grid">
      {filteredMods.map(mod => (
        <div class="card-wrapper" data-name={mod.name.toLowerCase()} data-tags={[...mod.tags, mod.category].join(',').toLowerCase()}>
          <ModCard
            slug={mod.slug}
            name={mod.name}
            summary={mod.summary}
            category={mod.category}
            tags={mod.tags}
          />
        </div>
      ))}
    </div>

    {filteredMods.length === 0 && (
      <div class="empty-state">
        <p>해당 조건에 맞는 모드가 없습니다.</p>
        <a href={`${base}mods/`} class="mc-btn">전체 보기</a>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('mod-search') as HTMLInputElement;
  const grid = document.getElementById('mod-grid');
  const cards = grid?.querySelectorAll('.card-wrapper');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    cards?.forEach(card => {
      const name = card.getAttribute('data-name') || '';
      const tags = card.getAttribute('data-tags') || '';
      const match = !query || name.includes(query) || tags.includes(query);
      (card as HTMLElement).style.display = match ? '' : 'none';
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: var(--space-6);
  }

  .page-header__title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-2);
  }

  .page-header__desc {
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
  }

  .filter-bar {
    margin-bottom: var(--space-4);
  }

  .search-bar {
    margin-bottom: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12);
    color: var(--text-muted);
  }

  @media (min-width: 640px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
