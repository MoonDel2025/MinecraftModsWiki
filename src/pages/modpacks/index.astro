---
/**
 * 모드팩 목록 페이지
 * 검색/필터/정렬 기능 포함
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModpackCard from '../../components/ModpackCard.astro';
import TagList from '../../components/TagList.astro';
import { getAllModpacks, getAllTags } from '../../utils/data';

const base = import.meta.env.BASE_URL;
const modpacks = getAllModpacks();
const allTags = getAllTags(modpacks);
const tag = Astro.url.searchParams.get('tag');
const filteredModpacks = tag
  ? modpacks.filter(mp => mp.tags.includes(tag))
  : modpacks;

const breadcrumbs = [
  { label: '홈', href: base },
  { label: '모드팩' },
];
---

<BaseLayout
  title="모드팩 목록"
  description="마인크래프트 인기 모드팩을 한눈에. 난이도, 버전, 장르별 필터로 원하는 모드팩을 찾아보세요."
  breadcrumbs={breadcrumbs}
>
  <section class="section container">
    <div class="page-header">
      <h1 class="page-header__title">모드팩 목록</h1>
      <p class="page-header__desc">
        총 {modpacks.length}개의 모드팩 정보가 있습니다.
        {tag && <span>현재 필터: <strong>{tag}</strong></span>}
      </p>
    </div>

    <!-- 필터 -->
    <div class="filter-bar">
      <TagList tags={allTags} baseUrl={`${base}modpacks/`} activeTag={tag || undefined} />
    </div>

    <!-- 검색 (클라이언트 사이드) -->
    <div class="search-bar">
      <input
        type="search"
        id="modpack-search"
        class="mc-search"
        placeholder="모드팩 이름으로 검색..."
        aria-label="모드팩 검색"
        style="padding-left: var(--space-4);"
      />
    </div>

    <!-- 모드팩 그리드 -->
    <div class="card-grid" id="modpack-grid">
      {filteredModpacks.map(mp => (
        <div class="card-wrapper" data-name={mp.name.toLowerCase()} data-tags={mp.tags.join(',')}>
          <ModpackCard
            slug={mp.slug}
            name={mp.name}
            summary={mp.summary}
            minecraftVersion={mp.minecraftVersion}
            loader={mp.loader}
            difficulty={mp.difficulty}
            tags={mp.tags}
            featured={mp.featured}
            coverImage={mp.coverImage}
          />
        </div>
      ))}
    </div>

    {filteredModpacks.length === 0 && (
      <div class="empty-state">
        <p>해당 조건에 맞는 모드팩이 없습니다.</p>
        <a href={`${base}modpacks/`} class="mc-btn">전체 보기</a>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  // 클라이언트 사이드 검색 필터
  const searchInput = document.getElementById('modpack-search') as HTMLInputElement;
  const grid = document.getElementById('modpack-grid');
  const cards = grid?.querySelectorAll('.card-wrapper');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    cards?.forEach(card => {
      const name = card.getAttribute('data-name') || '';
      const tags = card.getAttribute('data-tags') || '';
      const match = !query || name.includes(query) || tags.includes(query);
      (card as HTMLElement).style.display = match ? '' : 'none';
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: var(--space-6);
  }

  .page-header__title {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-2);
  }

  .page-header__desc {
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
  }

  .filter-bar {
    margin-bottom: var(--space-4);
  }

  .search-bar {
    margin-bottom: var(--space-6);
  }

  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12);
    color: var(--text-muted);
  }

  .empty-state p {
    margin-bottom: var(--space-4);
  }

  @media (min-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
